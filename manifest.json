{
  "manifest_version": 3,
  "name": "PatchFlow Edit Merge",
  "version": "1.0.0",
  "description": "PatchFlow Edit Merge for ChatGPT & Gemini. Crop a region, edit it via AI, and stitch it back seamlessly.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*"
  ],
  "action": {
    "default_title": "PatchFlow Edit Merge",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ]
}
